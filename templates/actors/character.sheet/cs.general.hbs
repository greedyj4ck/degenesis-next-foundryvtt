<section class="tab general {{tab.cssClass}}" data-group="main" data-tab="general">



  {{> "dgns.group.header" header="DGNS.Archetype" }}

  <div class="ccc-container">
    <div class="culture">
      {{#if culture}}
        <div class="controls">
          <label class="header">{{localize "DGNS.Culture"}}</label>
          {{#if (sheetEditMode mode) }}
            <!-- todo: add proper styilng -->
            <button type="button" data-action="removeLinkedItem" data-item-type="culture" class="">
              <i class="fas fa-eraser"></i>
            </button>
          {{/if}}
        </div>
        <div class="icon">
          <img src="{{culture.img}}" />
        </div>
        <div class="label">
          <label class="value">{{ culture.name }}</label>
        </div>
      {{else}}
        <div class="controls">
          <label class="header">{{localize "DGNS.Culture"}}</label>
        </div>
        <div class="icon">
          <div class="drop-placeholder"></div>
        </div>
        <div class="label">
          DROP ITEM
        </div>
      {{/if}}
    </div>
    <div class="concept">
      {{#if concept}}
        <div class="controls">
          <label class="header">{{localize "DGNS.Concept"}}</label>
          {{#if (sheetEditMode mode) }}
            <!-- todo: add proper styilng -->
            <button type="button" data-action="removeLinkedItem" data-item-type="concept" class="remove-cult">
              <i class="fas fa-eraser"></i>
            </button>
          {{/if}}
        </div>
        <div class="icon">
          <img src="{{concept.img}}" />
        </div>
        <div class="label">
          <label class="value">{{ concept.name }}</label>
        </div>
      {{else}}
        <div class="controls">
          <label class="header">{{localize "DGNS.Concept"}}</label>
        </div>
        <div class="icon">
          <div class="drop-placeholder"></div>
        </div>
        <div class="label">
          DROP ITEM
        </div>
      {{/if}}
    </div>
    <div class="cult">
      {{#if cult}}
        <div class="controls">
          <label class="header">
            {{#if (cult.isClan)}}{{localize "DGNS.Clan"}}{{else}}{{localize "DGNS.Cult"}}{{/if}}</label>
          {{#if (sheetEditMode mode) }}
            <!-- todo: add proper styilng -->
            <button type="button" data-action="removeLinkedItem" data-item-type="cult" class="remove-cult">
              <i class="fas fa-eraser"></i>
            </button>
          {{/if}}
        </div>
        <div class="icon">
          <img src="{{cult.img}}" data-action="showLinkedItem" data-item-type="cult" />
        </div>
        <div class="label">
          <label class="value">{{ cult.name }}</label>
        </div>
      {{else}}
        <div class="controls">
          <label class="header">{{localize "DGNS.Cult"}}</label>
        </div>
        <div class="icon">
          <div class="drop-placeholder"></div>
        </div>
        <div class="label">
          DROP ITEM
        </div>
      {{/if}}

    </div>
  </div>



  <!-- LEGACIES / POTENTIALS -->

  <div class="lp-container">

    <div class="legacies-container">
      <div class="legacies-toolbar">
        <label>{{localize "DGNS.Legacies"}}</label>
        <button>+</button>
      </div>

      <div class="legacies"></div>

    </div>

    <div class="potentials-container">
      <div class="potentials-toolbar">
        <label>{{localize "DGNS.Potentials"}}</label>
        <button>+</button>
      </div>

      <div class="potentials"></div>
    </div>

  </div>


  <!-- BACKGROUNDS -->



  <div class="backgrounds-container">
    <div class="header">
      {{> "dgns.group.header" header="DGNS.Backgrounds" }}
    </div>

    <div class="backgrounds">

      {{#each system.backgrounds}}
        <div class="field-under">
          <input class="field-input" type="number" name="system.backgrounds.{{@key}}" value="{{@this}}" />
          <label>{{localize @key}}</label>
        </div>
      {{/each}}
    </div>

  </div>






</section>