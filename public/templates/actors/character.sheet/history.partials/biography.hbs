<div class="biography-container section-dropdown" data-section="biography" data-collapsed="false">
    <div class="section-header biography-header ">
        <button type="button" class="dropdown-toggle" aria-label="Toggle dropdown">
            DROPDOWN
        </button>
        <div>{{localize "DGNS.Biography"}}</div>
    </div>

    <div class="section-body">
        <prose-mirror class="biography-editor" name="system.biography" data-document-u-u-i-d="{{document.uuid}}"
            value="{{system.biography}}" collaborate="true" toggled="true">
            {{{ enriched.biography }}}
        </prose-mirror>
    </div>

</div>